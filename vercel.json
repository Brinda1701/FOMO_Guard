{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "echo 'Deploying static site with API routes'",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/api/health", "destination": "/api/health.js" },
    { "source": "/api/analyze", "destination": "/api/analyze.js" },
    { "source": "/api/orchestrator", "destination": "/api/orchestrator.js" },
    { "source": "/api/scrape-url", "destination": "/api/scrape-url.js" },
    { "source": "/api/backtest", "destination": "/api/backtest.js" },
    { "source": "/api/multi-source", "destination": "/api/multi-source.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "github": {
    "silent": false,
    "autoJobCancelation": true
  }
}
