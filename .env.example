# FOMOGuard 环境变量配置
# 复制此文件为 .env.local 并填入真实值

# ==================== AI 配置 ====================
# 魔搭 ModelScope API 配置
# 请在 https://modelscope.cn 申请 API Key

# 1. 获取 API Key: https://modelscope.cn/my/token
MODELSCOPE_API_KEY=your_api_key_here

# 2. API URL (ModelScope 推理服务)
MODELSCOPE_API_URL=https://api-inference.modelscope.cn/v1/

# 3. 模型名称（需要在 Vercel 环境变量中配置）
#    请访问 https://modelscope.cn/docs/API-Inference/llm-api 查看当前支持的模型
#    推荐模型（任选其一，优先选择响应速度快的）：
#    - Qwen/Qwen2.5-32B-Instruct (默认，速度快，性能好)
#    - Qwen/Qwen2.5-14B-Instruct (更快)
#    - Qwen/Qwen2.5-72B-Instruct (较慢，可能超时)
#    - deepseek-ai/DeepSeek-V2.5
#    - deepseek-ai/DeepSeek-V2-Chat
#    - THUDM/chatglm3-6b
#    - 01-ai/Yi-34B-Chat
#    注意：超大模型（如 122B、397B）推理时间>60 秒，会导致 Vercel 超时！
MODEL_NAME=Qwen/Qwen2.5-32B-Instruct

# ==================== 真实 K 线数据配置 ====================
# 以下 API 用于获取真实的股票 K 线数据，至少配置其中一个

# --- 方案 1: Alpha Vantage (推荐，免费) ---
# 获取 API Key: https://www.alphavantage.co/support/#api-key (免费，5 次/分钟)
# 优点：完全免费，支持全球股票
# 缺点：频率限制较严格
ALPHA_VANTAGE_API_KEY=

# --- 方案 2: Twelve Data (备选) ---
# 获取 API Key: https://twelvedata.com/pricing (免费 800 次/天)
# 优点：额度充足，数据质量好
# 缺点：需要注册
TWELVE_DATA_API_KEY=

# --- 方案 3: Finnhub (备选) ---
# 获取 API Key: https://finnhub.io/dashboard (免费 60 次/分钟)
# 优点：额度充足，支持 A 股
# 缺点：需要注册
FINNHUB_API_KEY=

# --- 方案 4: 新浪财经接口 (无需 API Key，A 股专用) ---
# 直接启用，无需配置 Key
# 优点：无需注册，支持 A 股
# 缺点：仅限 A 股，数据格式需解析
ENABLE_SINA_API=true

# 默认数据源优先级（逗号分隔）
# 系统会按顺序尝试，直到获取成功
# 可选值：alphavantage, twelvedata, finnhub, sina
DATA_SOURCE_PRIORITY=alphavantage,twelvedata,finnhub,sina

# ==================== 安全配置 ====================
# CORS 允许的源（可选）
# 多个源用逗号分隔，例如：https://example.com,https://app.example.com
# 如果不配置，默认只允许 localhost:3000 和 127.0.0.1:3000
# 生产环境强烈建议配置此项
# ALLOWED_ORIGIN=https://your-domain.com
